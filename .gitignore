.DS_Store
.bsp/
.metals/
.scala-build/
project/target/
target/
modules/*/target/

# Local secrets — loaded by sbt-dotenv plugin; never commit
.env

# Editor / IDE / agent state — never commit
.idea/
.claude/
.agents/

# Local scratch / generated call-graph artifacts (graphviz)
predict-run-callgraph.*

# Docs site (MkDocs via uv) — build output lives in target/ (already ignored)
site/.venv/
.cache/
__pycache__/
