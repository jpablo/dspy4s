# Local environment variables loaded by sbt-dotenv during sbt startup.
# Never commit this file. See project/plugins.sbt and README for details.

# OpenAI API key — used by OpenAiLiveSuite integration tests.
# Get one from https://platform.openai.com/api-keys
# Cost per test run is ~0.01 USD (gpt-4o-mini, tiny prompts).
OPENAI_API_KEY=

# Opt-in flag — live HTTP calls are never made unless this is true.
# Set to `true` to hit the real OpenAI API during `sbt test`.
OPENAI_LIVE_ENABLED=false

# Optional: override the base URL to point at Azure OpenAI, OpenRouter,
# LiteLLM proxy, or a local recording mock server.
# OPENAI_BASE_URL=https://api.openai.com/v1
